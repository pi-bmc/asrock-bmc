# X570D4I-2T host BIOS update config, consumed by the meta-common generic
# bios-update.sh (phosphor-software-manager).
#
# The host BIOS SPI flash is shared between the AMD FCH (host) and the AST2500
# BMC's SPI1 controller (1e630000.spi) via a hardware mux on GPIOJ1.  Driving
# GPIOJ1 LOW hands the flash to the BMC; with the host powered off the BMC then
# binds spi1, the flash enumerates as the "bios" MTD, and flashcp writes it.
# (Discovered from stock MegaRAC: BIOS_SPI_GPIO_PIN="J1", LEVEL=0.)  This
# bypasses AMI Secure Flash and the AMD PSP SPI host-access lock, which only
# guard the host/FCH path, not the BMC's own SPI1 controller.
#
# The host must already be powered off before the update (the generic script
# checks and refuses otherwise).

BIOS_UPDATE_PREP_GPIOS=(
  control-bios-spi-mux-n=0
)
BIOS_UPDATE_MAGIC_OFFSET=$((0x20000))
BIOS_UPDATE_MAGIC=aa55aa55
BIOS_UPDATE_SIZE=$((32 << 20))
